---

# unbound variant (DNS-over-TLS -> Quad9) — the CURRENTLY ACTIVE
# upstream.
#
# AdGuard -> unbound (DoT on :853) -> Quad9. Encrypts external
# queries so the ISP cannot see them; unbound validates DNSSEC and caches. The
# build lives in docker/unbound/ (Dockerfile + data/unbound.sh); unbound.conf
# and forward-records.conf are bind-mounted read-only from the repo so config
# edits deploy via Komodo redeploy without an image rebuild. Resource-tuned
# values are generated into dynamic.conf at container start. unbound listens on
# 127.0.0.1:5335, which is AdGuard's default upstream_dns.
#
# This mirrors the live service blocks in services/adguard-<n>/docker-compose.yml.
# To swap back to Anonymized DNSCrypt, see dnscrypt-proxy.example.
# To switch to a recursive resolver (no upstream forwarder), see
# unbound-recursive.example.

# services:

  # Unbound - DNS-over-TLS forwarder to Quad9 with DNSSEC validation
  # unbound-1:
  #   image: ${REGISTRY_IMAGE}/unbound:1.25.1
  #   container_name: unbound-1
  #   network_mode: host
  #   environment:
  #     TZ: ${TZ}
  #     # UNBOUND_CACHE_PERCENTAGE: "40"   # optional per-host cache tuning (1-90)
  #   volumes:
  #     - ../../docker/unbound/data/opt/unbound/etc/unbound/unbound.conf:/opt/unbound/etc/unbound/unbound.conf:ro
  #     - ../../docker/unbound/data/opt/unbound/etc/unbound/forward-records.conf:/opt/unbound/etc/unbound/forward-records.conf:ro
  #   restart: unless-stopped

  # Unbound - DNS-over-TLS forwarder to Quad9 with DNSSEC validation
  # unbound-2:
  #   image: ${REGISTRY_IMAGE}/unbound:1.25.1
  #   container_name: unbound-2
  #   network_mode: host
  #   environment:
  #     TZ: ${TZ}
  #     # UNBOUND_CACHE_PERCENTAGE: "40"   # optional per-host cache tuning (1-90)
  #   volumes:
  #     - ../../docker/unbound/data/opt/unbound/etc/unbound/unbound.conf:/opt/unbound/etc/unbound/unbound.conf:ro
  #     - ../../docker/unbound/data/opt/unbound/etc/unbound/forward-records.conf:/opt/unbound/etc/unbound/forward-records.conf:ro
  #   restart: unless-stopped
