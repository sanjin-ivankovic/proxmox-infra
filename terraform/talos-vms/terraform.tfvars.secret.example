# ============================================================================
# Talos VMs - Terraform Variables Example
# ============================================================================
# Copy this file to terraform.tfvars.secret and fill in your values.
#
# Usage:
#   cp terraform.tfvars.secret.example terraform.tfvars.secret
#   nano terraform.tfvars.secret
# ============================================================================

# ============================================================================
# 1. Proxmox Connection (REQUIRED)
# ============================================================================

proxmox_api_url          = "https://10.10.0.4:8006/api2/json"
proxmox_api_token_id     = "terraform-prov@pve!terraform"
proxmox_api_token_secret = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ============================================================================
# 2. Infrastructure Defaults
# ============================================================================

target_node     = "pve"       # Default Proxmox node
default_storage = "local-zfs" # Default storage (local-zfs, local-lvm, etc.)
default_bridge  = "vmbr0"     # Default network bridge

# ============================================================================
# 3. Talos-Specific Configuration
# ============================================================================

talos_iso_storage = "local"               # Proxmox storage containing Talos ISO
talos_iso_file    = "nocloud-amd64.iso"   # Talos ISO filename

# ============================================================================
# VM Instances
# ============================================================================
# VM instances are defined in instances/talos.auto.tfvars
# Edit that file to add/modify/remove Talos VMs
