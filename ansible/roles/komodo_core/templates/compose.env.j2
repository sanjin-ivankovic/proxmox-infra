## {{ ansible_managed }}
## Komodo Core environment — rendered by the komodo_core Ansible role.
## Contains secrets; mode 0600.

KOMODO_HOST={{ komodo_core_host }}
KOMODO_PORT={{ komodo_core_port }}
KOMODO_TITLE={{ komodo_core_title }}

KOMODO_LOCAL_AUTH={{ komodo_core_local_auth | lower }}
KOMODO_DISABLE_USER_REGISTRATION={{ komodo_core_disable_user_registration | lower }}

# First admin, created on boot (registration stays disabled).
KOMODO_INIT_ADMIN_USERNAME={{ komodo_core_init_admin_username }}
KOMODO_INIT_ADMIN_PASSWORD={{ komodo_core_init_admin_password }}

KOMODO_WEBHOOK_SECRET={{ komodo_core_webhook_secret }}
KOMODO_JWT_SECRET={{ komodo_core_jwt_secret }}

KOMODO_DATABASE_USERNAME={{ komodo_core_db_username }}
KOMODO_DATABASE_PASSWORD={{ komodo_core_db_password }}
KOMODO_DATABASE_DB_NAME={{ komodo_core_db_name }}
